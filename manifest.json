{
  "manifest_version": 3,
  "name": "Smart Privacy",
  "version": "1.0.0",
  "description": "Automatically removes cookies and site data for sites not on your approve list. Prompts you when you visit a site repeatedly or enter a password.",
  "browser_specific_settings": {
    "gecko": {
      "id": "smart-privacy@emanuelen5",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    },
    "gecko_android": {}
  },
  "permissions": [
    "cookies",
    "tabs",
    "storage",
    "browsingData"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": ["dist/background.js"]
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["dist/content.js"],
      "css": ["static/content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "static/popup/popup.html",
    "default_title": "Smart Privacy",
    "default_icon": {
      "48": "static/icons/icon.svg",
      "96": "static/icons/icon.svg"
    }
  },
  "options_ui": {
    "page": "static/options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "48": "static/icons/icon.svg",
    "96": "static/icons/icon.svg"
  }
}
